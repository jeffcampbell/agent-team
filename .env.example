# Yamanote configuration
# Path to the parent directory containing your project(s)
# export AGENT_TEAM_DEV_DIR=~/Development

# Name of the default project directory to manage (under AGENT_TEAM_DEV_DIR)
# export AGENT_TEAM_DEFAULT_PROJECT=my-app

# Glob pattern for app log file(s) relative to the project root (leave empty to skip)
# export AGENT_TEAM_APP_LOG_GLOB=app.log

# Claude CLI command (default: "claude")
# export CLAUDE_CMD=claude

# Command to restart your app after a merge (leave empty to skip)
# export AGENT_TEAM_SERVICE_RESTART_CMD=sudo systemctl restart your-app.service

# Railway deployment (alternative to SERVICE_RESTART_CMD)
# When set, the orchestrator uses `railway logs` for monitoring and
# `railway up` for deployment (staging first, then production).
# export AGENT_TEAM_RAILWAY_PROJECT=my-railway-project
# export AGENT_TEAM_RAILWAY_SERVICE=my-railway-service
# export AGENT_TEAM_RAILWAY_STAGING_ENV=staging
# export AGENT_TEAM_RAILWAY_PRODUCTION_ENV=production

# Web dashboard port (uncomment to enable; or use --dashboard CLI flag)
# export AGENT_TEAM_DASHBOARD_PORT=8080
